# Lightspeed API Configuration
# Get these values from your Lightspeed account
VITE_LIGHTSPEED_API_URL=https://api.lightspeedapp.com/API
VITE_LIGHTSPEED_API_KEY=your_api_key_here
VITE_LIGHTSPEED_ACCOUNT_ID=your_account_id_here

# Contact form (Formspree)
# 1. Go to formspree.io and create a free account
# 2. Create a new form — you'll get an endpoint like https://formspree.io/f/xxxxxxxx
# 3. Add that URL here and to your deployment environment variables
VITE_FORMSPREE_URL=https://formspree.io/f/your_form_id_here

# Google Analytics 4
# 1. Create a GA4 property at analytics.google.com
# 2. Copy your Measurement ID (looks like G-XXXXXXXXXX)
# 3. Add it here AND to your deployment environment variables (GitHub Actions secret)
# Leave blank/unset to disable analytics — gtag will not load.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
